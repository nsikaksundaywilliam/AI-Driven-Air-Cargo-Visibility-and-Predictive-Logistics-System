      ],
      "id": "2e33fbc7-03c7-4e47-8139-37cffb29c4fd",
      "name": "Gemini AI Decision Engine"
    },
    {
      "parameters": {
        "jsCode": "const ai = $input.first().json.output || {};\n\nconst cargo = $(\"Compute Operational Risk\").first().json;\n\nreturn [{\n  json: {\n\n    //========================\n    // Shipment\n    //========================\n    cargo_id: cargo.cargo_id,\n    awb_number: cargo.awb_number,\n\n    origin_airport: cargo.origin_airport,\n    destination_airport: cargo.destination_airport,\n\n    shipment_stage: cargo.shipment_stage,\n    cargo_status: cargo.cargo_status,\n\n    current_location: cargo.current_location,\n\n    shipper_name: cargo.shipper_name,\n    consignee_name: cargo.consignee_name,\n\n    cargo_type: cargo.cargo_type,\n    priority_level: cargo.priority_level,\n\n    //========================\n    // Weather\n    //========================\n    weather_condition: cargo.weather_condition,\n    temperature_2m: cargo.temperature_2m,\n    precipitation: cargo.precipitation,\n    rain: cargo.rain,\n    wind_speed_10m: cargo.wind_speed_10m,\n    visibility: cargo.visibility,\n    cloud_cover: cargo.cloud_cover,\n\n    //========================\n    // Risk Scores\n    //========================\n    weather_risk_score: cargo.weather_risk_score,\n    cargo_risk_score: cargo.cargo_risk_score,\n    route_risk_score: cargo.route_risk_score,\n    total_risk_score: cargo.total_risk_score,\n\n    delay_hours: cargo.delay_hours,\n    route_status: cargo.route_status,\n\n    event_timestamp: cargo.event_timestamp,\n\n    //========================\n    // AI Intelligence\n    //========================\n    delay_risk: ai.delay_risk_level,\n    recommended_action: ai.recommended_action\n\n  }\n}];"
