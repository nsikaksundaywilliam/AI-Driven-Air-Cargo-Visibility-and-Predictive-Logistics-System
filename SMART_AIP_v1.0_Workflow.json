        "query": "INSERT INTO shipments (\n    cargo_id,\n    awb_number,\n    origin_airport,\n    destination_airport,\n    current_location,\n    current_status,\n    shipment_stage,\n    flight_number,\n    shipper_name,\n    consignee_name,\n    cargo_type,\n    priority_level,\n    weather_condition,\n    route_status,\n    delay_hours,\n    last_event_timestamp,\n    updated_at\n)\nVALUES (\n    '{{ $json.cargo_id }}',\n    '{{ $json.awb_number }}',\n    '{{ $json.origin_airport }}',\n    '{{ $json.destination_airport }}',\n    '{{ $json.current_location }}',\n    '{{ $json.cargo_status }}',\n    '{{ $json.shipment_stage }}',\n    '{{ $json.flight_number }}',\n    '{{ $json.shipper_name }}',\n    '{{ $json.consignee_name }}',\n    '{{ $json.cargo_type }}',\n    '{{ $json.priority_level }}',\n    '{{ $json.weather_condition }}',\n    '{{ $json.route_status }}',\n    {{ $json.delay_hours }},\n    '{{ $json.event_timestamp }}',\n    CURRENT_TIMESTAMP\n)\nON CONFLICT (awb_number)\nDO UPDATE SET\n    cargo_id = EXCLUDED.cargo_id,\n    origin_airport = EXCLUDED.origin_airport,\n    destination_airport = EXCLUDED.destination_airport,\n    current_location = EXCLUDED.current_location,\n    current_status = EXCLUDED.current_status,\n    shipment_stage = EXCLUDED.shipment_stage,\n    flight_number = EXCLUDED.flight_number,\n    shipper_name = EXCLUDED.shipper_name,\n    consignee_name = EXCLUDED.consignee_name,\n    cargo_type = EXCLUDED.cargo_type,\n    priority_level = EXCLUDED.priority_level,\n    weather_condition = EXCLUDED.weather_condition,\n    route_status = EXCLUDED.route_status,\n    delay_hours = EXCLUDED.delay_hours,\n    last_event_timestamp = EXCLUDED.last_event_timestamp,\n    updated_at = CURRENT_TIMESTAMP\nRETURNING *;",
