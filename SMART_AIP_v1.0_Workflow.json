      "name": "Retrieve Weather Intelligence"
    },
    {
      "parameters": {
        "jsCode": "// Get shipment data from the previous node\nconst shipment = $('Upsert Shipment Record').first().json;\n\n// Get weather data\nconst weather = $json.current || {};\n\n// Determine weather condition\nlet weatherCondition = \"Clear\";\n\nif ((weather.rain || 0) > 0) {\n  weatherCondition = \"Rain\";\n}\n\nif ((weather.wind_speed_10m || 0) > 30) {\n  weatherCondition = \"High Wind\";\n}\n\n// ---------- FORCE HIGH RISK ----------\nconst weatherRisk = 90;\nconst cargoRisk = 90;\nconst routeRisk = 90;\nconst totalRiskScore = 90;\n\nconst delayRisk = \"High\";\n\nconst recommendedAction =\n  \"Escalate immediately, notify operations team, notify customer, and activate contingency plan.\";\n\nreturn [\n  {\n    json: {\n\n      cargo_id: shipment.cargo_id,\n      awb_number: shipment.awb_number,\n\n      origin_airport: shipment.origin_airport,\n      destination_airport: shipment.destination_airport,\n\n      current_location: shipment.current_location,\n\n      shipment_stage: shipment.shipment_stage,\n\n      cargo_status: shipment.current_status,\n\n      shipper_name: shipment.shipper_name,\n      consignee_name: shipment.consignee_name,\n\n      cargo_type: shipment.cargo_type,\n      priority_level: shipment.priority_level,\n\n      weather_condition: weatherCondition,\n\n      temperature_2m: weather.temperature_2m,\n      precipitation: weather.precipitation,\n      rain: weather.rain,\n      wind_speed_10m: weather.wind_speed_10m,\n      visibility: weather.visibility,\n      cloud_cover: weather.cloud_cover,\n\n      weather_risk_score: weatherRisk,\n      cargo_risk_score: cargoRisk,\n      route_risk_score: routeRisk,\n      total_risk_score: totalRiskScore,\n\n      delay_risk: delayRisk,\n\n      recommended_action: recommendedAction,\n\n      risk_flags: [\n        \"High Risk Test\"\n      ],\n\n      route_status: shipment.route_status,\n\n      delay_hours: shipment.delay_hours,\n\n      event_timestamp:\n        shipment.last_event_timestamp || new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -5472,
        416
      ],
      "id": "9427694c-1bb8-4328-b0f7-d818db15b858",
      "name": "Compute Operational Risk"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Cargo ID: {{$json.cargo_id}}\n\nCargo Status: {{$json.cargo_status}}\n\nDelay Hours: {{$json.delay_hours}}\n\nWeather Condition: {{$json.weather_condition}}\n\nTemperature: {{$json.temperature}}\n\nRain: {{$json.rain}}\n\nWind Speed: {{$json.wind_speed}}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an aviation cargo logistics risk analyst.\n\nAnalyze the shipment information and determine:\n\n1. delay_risk_level\n2. recommended_action\n\nRules:\n\n- delay_hours > 4 = High\n- delay_hours between 2 and 4 = Medium\n- delay_hours < 2 = Low\n\nIf weather_condition is Rain or High Wind, increase risk by one level.\n\nReturn ONLY the structured output.\nDo not include explanations."
        }
      },
