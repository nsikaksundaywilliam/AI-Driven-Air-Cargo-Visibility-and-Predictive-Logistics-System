    {
      "parameters": {
        "jsCode": "const mock = {\n  cargo_id: \"CG001\",\n  awb_number: \"AWB123456\",\n  origin_airport: \"LOS\",\n  destination_airport: \"ABV\",\n  current_location: \"Murtala Muhammed International Airport Cargo Terminal, Lagos\",\n  cargo_status: \"In Transit\",\n  event_timestamp: \"2026-06-25T10:15:00Z\",\n  weather_condition: \"Thunderstorm\",\n  route_status: \"Congested\",\n  delay_hours: 2,\n  shipper_name: \"ABC Pharma Ltd\",\n  flight_number: \"P4-7123\",\n  consignee_name: \"XYZ Medical Stores\",\n  cargo_type: \"Pharmaceuticals\",\n  priority_level: \"High\"\n};\n\nfunction normalizeStatus(status) {\n  const s = (status || \"\").toString().trim().toLowerCase();\n\n  if ([\"booked\", \"booking confirmed\"].includes(s)) return \"Booked\";\n  if ([\"received\", \"received at terminal\", \"cargo received\"].includes(s)) return \"Received at Cargo Terminal\";\n  if ([\"processing\", \"under processing\"].includes(s)) return \"Under Processing\";\n  if ([\"loaded\", \"loaded on flight\"].includes(s)) return \"Loaded on Flight\";\n  if ([\"in transit\", \"transit\"].includes(s)) return \"In Transit\";\n  if ([\"arrived\", \"arrived at destination\"].includes(s)) return \"Arrived at Destination\";\n  if ([\"customs\", \"under customs clearance\", \"customs clearance\"].includes(s)) return \"Under Customs Clearance\";\n  if ([\"ready for pickup\", \"pickup\"].includes(s)) return \"Ready for Pickup\";\n  if ([\"delivered\", \"released\"].includes(s)) return \"Delivered\";\n  if ([\"delayed\", \"exception\"].includes(s)) return \"Delayed / Exception\";\n\n  return \"Under Processing\";\n}\n\nfunction deriveShipmentStage(status) {\n  switch (status) {\n    case \"Booked\":\n      return \"Pre-Shipment\";\n    case \"Received at Cargo Terminal\":\n    case \"Under Processing\":\n      return \"Origin Terminal Handling\";\n    case \"Loaded on Flight\":\n    case \"In Transit\":\n      return \"Air Transit\";\n    case \"Arrived at Destination\":\n      return \"Destination Arrival\";\n    case \"Under Customs Clearance\":\n      return \"Customs Clearance\";\n    case \"Ready for Pickup\":\n      return \"Last-Mile Release\";\n    case \"Delivered\":\n      return \"Completed\";\n    case \"Delayed / Exception\":\n      return \"Exception Management\";\n    default:\n      return \"Origin Terminal Handling\";\n  }\n}\n\nconst cargoStatus = normalizeStatus(mock.cargo_status);\nconst normalized = {\n  cargo_id: mock.cargo_id,\n  awb_number: mock.awb_number,\n  origin_airport: mock.origin_airport,\n  destination_airport: mock.destination_airport,\n  current_location: mock.current_location,\n  cargo_status: cargoStatus,\n  event_timestamp: mock.event_timestamp,\n  flight_number: mock.flight_number,\n  shipper_name: mock.shipper_name,\n  consignee_name: mock.consignee_name,\n  cargo_type: mock.cargo_type,\n  priority_level: mock.priority_level,\n  weather_condition: mock.weather_condition,\n  route_status: mock.route_status,\n  delay_hours: Number(mock.delay_hours),\n  shipment_stage: deriveShipmentStage(cargoStatus),\n  risk_inputs: {\n    weather_condition: mock.weather_condition,\n    route_status: mock.route_status,\n    delay_hours: Number(mock.delay_hours),\n    priority_level: mock.priority_level,\n    cargo_type: mock.cargo_type\n  }\n};\n\nreturn [{ json: normalized }];"
      },
